---
import Layout from '../../layouts/layout.astro';
import items from '../../data/products.json';

export function getStaticPaths() {
  return items.map((item) => ({
    params: { slug: item.slug },
    props: { item },
  }));
}

const { item } = Astro.props;
---

<Layout>
  <div class="grid grid-cols-2 gap-4">
    <div
      class="h-screen w-full bg-gray-200 flex items-center justify-center text-gray-400"
    >
      {item.image}
    </div>
    <div class="flex flex-col gap-4">
      <p class="text-gray-700"># {item.category}</p>
      <h1 class="text-4xl font-medium text-gray-700">{item.title}</h1>
      <ul class="list-disc pl-5">
        <li class="text-gray-700">{item.description}</li>
        <li class="text-gray-700">Product ID: {item.id}</li>
      </ul>
      <h2 class="text-2xl font-bold text-gray-700">${item.price.toFixed(2)}</h2>
      <p class="text-gray-700">{item.inStock ? 'In Stock' : 'Out of Stock'}</p>
      <a
        href="#"
        class="flex justify-center px-4 py-4 border hover:border-gray-500 hover:text-gray-500 hover:bg-gray-300 bg-gray-500 text-white transition-colors"
      >
        Add to Cart
      </a>
    </div>
  </div>
</Layout>
